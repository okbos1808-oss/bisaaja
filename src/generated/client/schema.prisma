generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String       @id @default(cuid())
  name          String?
  email         String?      @unique
  emailVerified DateTime?    @map("email_verified")
  image         String?
  password      String?
  role          String       @default("user")
  // FIX: renamed Permohonan -> permohonan (Prisma convention: relation fields are camelCase)
  permohonan    Permohonan[]
  accounts      Account[]
  sessions      Session[]
  validasi      Validasi[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Validasi {
  id           String           @id @default(cuid())
  permohonanId String           @unique
  adminId      String
  // FIX: was String — use the shared enum for consistency with Permohonan.status
  status       StatusPermohonan
  catatan      String?
  createdAt    DateTime         @default(now())
  // FIX: added updatedAt so you can track when a validation was last changed
  updatedAt    DateTime         @updatedAt
  admin        User             @relation(fields: [adminId], references: [id])
  permohonan   Permohonan       @relation(fields: [permohonanId], references: [id], onDelete: Cascade)

  @@map("validasi")
}

model KomentarPermohonan {
  id           String     @id @default(cuid())
  permohonanId String
  adminName    String
  isi          String
  createdAt    DateTime   @default(now())
  permohonan   Permohonan @relation(fields: [permohonanId], references: [id], onDelete: Cascade)

  @@map("komentar_permohonan")
}

model Permohonan {
  id     String @id @default(cuid())
  userId String

  namaUsaha String
  divisi    String
  layanan   String
  noHp      String
  email     String
  alamat    String

  fileDokumen String?

  status StatusPermohonan @default(PENDING)

  // Penawaran harga
  hargaPenawaran Decimal? @db.Decimal(15, 2)
  catatanHarga   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  komentar KomentarPermohonan[]
  validasi Validasi?

  @@index([userId])
  @@map("permohonan")
}

enum StatusPermohonan {
  PENDING
  DISETUJUI
  SCREENING_ANALISA_KEBUTUHAN
  PENAWARAN_HARGA_PENETAPAN_BIAYA
  PENGUMPULAN_DOKUMEN
  PEMBUATAN_AKUN_SISTEM_PEMERINTAH
  PENYUSUNAN_DOKUMEN_PERIZINAN
  SUBMIT_PENGAJUAN
  VERIFIKASI_PEMERINTAH
  AUDIT_VISITASI_PEMERIKSAAN
  PERBAIKAN_HASIL_AUDIT
  SUBMIT_PERBAIKAN
  PERSETUJUAN_DAN_PENERBITAN_SERTIFIKAT
  CLOSING_DAN_MAINTENANCE_CLIENT
}

// FIX: extracted Pembayaran status into its own enum
enum StatusPembayaran {
  MENUNGGU_VERIFIKASI
  TERVERIFIKASI
  DITOLAK
}
